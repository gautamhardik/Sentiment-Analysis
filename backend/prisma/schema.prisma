generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Prediction {
  id              String   @id @default(cuid())
  sessionId       String
  text            String
  lrResult        String
  lstmResult      String
  bertResult      String
  majorityLabel   String
  agreement       String
  totalLatencyMs  Float
  createdAt       DateTime @default(now())

  @@index([sessionId])
}

model ModelMetric {
  id        String   @id @default(cuid())
  modelName String   @unique
  accuracy  Float
  precision Float
  recall    Float
  f1        Float
  params    Int
  sizeBytes   BigInt
  inferenceMs Float
  updatedAt DateTime @updatedAt
}
